(env
  (dev
    (ocamlopt_flags (:standard -O3 -fPIC -ccopt -O3 -ccopt -fPIC -ccopt -fopenmp)))
  (release
    (ocamlopt_flags (:standard -O3 -fPIC -ccopt -O3 -ccopt -fPIC -ccopt -fopenmp -ccopt -static))))

(executables
 (public_names KPopCount KPopCountDB KPopTwist_ KPopTwistDB)
 (names KPopCount KPopCountDB KPopTwist_ KPopTwistDB)
 (libraries str unix zarith BiOCamLib KPop)
; (link_flags (-verbose -cclib -lgfortran -cclib -lquadmath -cclib -lstdc++))
 (link_flags (-cclib -lgfortran -cclib -lquadmath -cclib -lstdc++)))

(install
 (section bin)
 (files
  (KPopCount.exe as KPopCount)
  (KPopCountDB.exe as KPopCountDB)
  (KPopTwist_.exe as KPopTwist_)
  (KPopTwistDB.exe as KPopTwistDB)))
